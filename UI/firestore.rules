rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. GLOBAL SAFETY NET
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. REUSABLE, HARDENED GLOBAL HELPERS
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. ENTITY-SPECIFIC BINDING VALIDATIONS
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt']) 
        && data.keys().size() >= 4 && data.keys().size() <= 8
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 150
        && (data.name == null || (data.name is string && data.name.size() <= 100))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500))
        && (data.favoriteHubId == null || (data.favoriteHubId is string && data.favoriteHubId.size() <= 50))
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidRsvp(data) {
      return data.keys().hasAll(['rsvpId', 'userId', 'eventId', 'hubId', 'eventTitle', 'registeredAt'])
        && data.keys().size() == 6
        && data.rsvpId == (data.userId + '_' + data.eventId)
        && data.userId == request.auth.uid
        && data.eventId is string && data.eventId.size() <= 64
        && data.hubId is string && data.hubId.size() <= 64
        && data.eventTitle is string && data.eventTitle.size() <= 200
        && data.registeredAt is timestamp;
    }

    function isValidLike(data) {
      return data.keys().hasAll(['likeId', 'userId', 'eventId', 'hubId', 'likedAt'])
        && data.keys().size() == 5
        && data.likeId == (data.userId + '_' + data.eventId)
        && data.userId == request.auth.uid
        && data.eventId is string && data.eventId.size() <= 64
        && data.hubId is string && data.hubId.size() <= 64
        && data.likedAt is timestamp;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['userId', 'role', 'content', 'timestamp'])
        && data.keys().size() == 4
        && data.userId == request.auth.uid
        && data.role in ['user', 'assistant']
        && data.content is string && data.content.size() <= 10000
        && data.timestamp is timestamp;
    }

    // 4. COLLECTION MATCH RULES

    // /users/{userId}
    match /users/{userId} {
      allow get: if isSignedIn(); 
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == existing().createdAt && incoming().updatedAt == request.time;
      allow delete: if false; // Profiles are permanent

      // /users/{userId}/chatHistory/{messageId}
      match /chatHistory/{messageId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidChatMessage(incoming()) && incoming().timestamp == request.time;
        allow update, delete: if false; // Chat items are immutable log
      }
    }

    // /rsvps/{rsvpId}
    match /rsvps/{rsvpId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidRsvp(incoming()) && incoming().registeredAt == request.time;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    // /likes/{likeId}
    match /likes/{likeId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidLike(incoming()) && incoming().likedAt == request.time;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
